# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for LOCAL development.
# NEVER commit the real .env file to version control.
#
# Streamlit Cloud: add these as Secrets under Settings → Secrets (TOML format):
#   OPENAI_API_KEY        = "sk-..."
#   NOTION_TOKEN          = "secret_..."
#   NOTION_PARENT_PAGE_ID = "your-page-id"
#
# Google Colab: set via os.environ["KEY"] = "value" in a notebook cell.
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Notion integration token — https://www.notion.so/my-integrations
# The integration must be shared with the parent page (see README).
NOTION_TOKEN=secret_...

# The ID of the Notion page under which lecture pages will be created.
# Copy from the page URL: https://www.notion.so/<workspace>/<PAGE_ID>
# Use only the 32-character hex ID, e.g.: 1234abcd5678efgh9012ijkl3456mnop
NOTION_PARENT_PAGE_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Optional tuning
# ─────────────────────────────────────────────────────────────────────────────

# Logging verbosity: DEBUG | INFO | WARNING | ERROR  (default: INFO)
LOG_LEVEL=INFO

# Audio chunk length in seconds sent to Whisper (default: 600 = 10 min)
# At 32 kbps mono MP3, 600 s ≈ 2.4 MB — safely under Whisper's 25 MB limit.
# CHUNK_DURATION_S=600

# Overlap between consecutive audio chunks in seconds (default: 30)
# Duplicate sentences at seams are removed by fuzzy deduplication.
# CHUNK_OVERLAP_S=30
