# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Notion integration token — https://www.notion.so/my-integrations
# The integration must be shared with the parent page (see README).
NOTION_TOKEN=secret_...

# The ID of the Notion page under which lecture pages will be created.
# Found in the page URL: https://www.notion.so/<workspace>/<PAGE_ID>?v=...
# Use only the 32-character hex ID, e.g.: 1234abcd5678efgh9012ijkl3456mnop
NOTION_PARENT_PAGE_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Optional tuning parameters
# ─────────────────────────────────────────────────────────────────────────────

# Logging verbosity: DEBUG | INFO | WARNING | ERROR  (default: INFO)
LOG_LEVEL=INFO

# Maximum audio chunk size sent to Whisper API, in bytes (default: 20 MB)
# MAX_CHUNK_BYTES=20971520

# Overlap in milliseconds between audio chunks (default: 30 000 ms = 30 s)
# CHUNK_OVERLAP_MS=30000
